FROM node:24-alpine AS web

WORKDIR /app

ENV NODE_ENV=development

COPY package.json package-lock.json turbo.json tsconfig.base.json .npmrc ./
COPY apps/web/package.json apps/web/package.json
COPY packages/shared/package.json packages/shared/package.json

RUN npm ci --include=dev

COPY apps/web apps/web
COPY packages packages

RUN npm run build -w @voxlink/shared
RUN npm run build -w @voxlink/web

ENV NODE_ENV=production

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 CMD node -e "fetch('http://127.0.0.1:' + (process.env.PORT || '3000') + '/ready').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["npm", "run", "start", "-w", "@voxlink/web"]
