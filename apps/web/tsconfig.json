{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "incremental": true,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@altrion/shared": ["../../packages/shared/src/index.ts"],
      "@altrion/stt": ["../../services/stt/src/index.ts"],
      "@altrion/tts": ["../../services/tts/src/index.ts"],
      "@altrion/llm": ["../../services/llm/src/index.ts"],
      "@altrion/telephony": ["../../services/telephony/src/index.ts"],
      "@altrion/rag": ["../../services/rag/src/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
