NODE_ENV=development
TRUST_PROXY=false

POSTGRES_DB=voxlink_voice
POSTGRES_USER=voxlink
POSTGRES_PASSWORD=voxlink_dev_password
DATABASE_URL=postgresql://voxlink:voxlink_dev_password@localhost:5432/voxlink_voice?schema=public

REDIS_URL=redis://localhost:6379

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_SEND_TIMEOUT_MS=10000
MAIL_FROM="VoxLink Voice <no-reply@voxlink.local>"

API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000
WEB_ORIGIN=http://localhost:3000

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
COOKIE_SECRET=replace-with-cookie-secret-at-least-32-chars

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:4000/auth/google/callback

BILLING_PROVIDER=internal
ALLOW_INTERNAL_BILLING_IN_PRODUCTION=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_BASE_URL=https://api.stripe.com
STRIPE_PROVIDER_TIMEOUT_MS=10000
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_GROWTH=
STRIPE_PRICE_ID_SCALE=

BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_SUPER_ADMIN_PASSWORD=replace-with-at-least-12-chars
BOOTSTRAP_SUPER_ADMIN_NAME=Platform Admin
BOOTSTRAP_SUPER_ADMIN_RESET_PASSWORD=false
BOOTSTRAP_COMPANY_NAME=VoxLink Platform
BOOTSTRAP_COMPANY_SLUG=voxlink-platform

TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_API_BASE_URL=https://api.twilio.com
TWILIO_PROVIDER_TIMEOUT_MS=10000
TWILIO_WEBHOOK_BASE_URL=https://example.ngrok-free.app
TWILIO_TEST_FROM_NUMBER=
TWILIO_TEST_TO_NUMBER=

# Do not commit real provider keys. Use fresh Groq keys here as comma-separated values.
GROQ_API_KEYS=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_PROVIDER_TIMEOUT_MS=20000
GROQ_LLM_DEFAULT_PROFILE=llama
GROQ_LLM_MODEL_LLAMA=llama-3.3-70b-versatile
GROQ_LLM_MODEL_GEMMA=gemma2-9b-it
# Mixtral is not always available on current Groq projects. Set this only if enabled for your account.
GROQ_LLM_MODEL_MIXTRAL=
GROQ_LLM_MODEL_GPT=openai/gpt-oss-120b
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_TTS_MODEL=canopylabs/orpheus-v1-english
